# ─── WP Infra NOC — Variáveis de Ambiente ─────────────────────
# Copie este arquivo para .env e ajuste os valores
# O arquivo .env NUNCA deve ser commitado no repositório

# Servidor
HOST=0.0.0.0
PORT=8000

# Monitoramento
DEFAULT_INTERVAL_SECONDS=30
DEFAULT_TIMEOUT_SECONDS=5

# Log
LOG_LEVEL=INFO
LOG_MAX_ENTRIES=2000
